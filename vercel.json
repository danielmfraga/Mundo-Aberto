{
  "functions": {
    "api/navegador.js":       { "maxDuration": 60 },
    "api/ingest-session.js":  { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/sheet-sync.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    }
  ]
}
