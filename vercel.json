{
  "redirects": [
    { "source": "/diario", "destination": "/", "permanent": false },
    { "source": "/diario.html", "destination": "/", "permanent": false }
  ],
  "functions": {
    "api/navegador.js":       { "maxDuration": 60 },
    "api/ingest-session.js":  { "maxDuration": 120 },
    "api/jaas-webhook.js":    { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/sheet-sync.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    }
  ]
}
