<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Personagens · Daniel Fraga · Caçador A Revanche</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      background: #06090c; 
      display: flex; 
      align-items: center; 
      justify-content: center; 
      min-height: 100vh; 
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: #cfe9f0;
    }
    .container {
      width: 100%;
      max-width: 900px;
      padding: 40px 20px;
    }
    h1 {
      text-align: center;
      color: #4ed3e8;
      font-size: 36px;
      letter-spacing: 6px;
      margin-bottom: 10px;
      text-transform: uppercase;
    }
    .subtitle {
      text-align: center;
      color: #ff7a3d;
      font-size: 14px;
      letter-spacing: 4px;
      margin-bottom: 40px;
      opacity: 0.8;
    }
    .btn-container {
      display: flex;
      gap: 15px;
      justify-content: center;
      margin-bottom: 30px;
    }
    .btn {
      padding: 12px 24px;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .btn-add {
      background: linear-gradient(135deg, #4ed3e8, #2cb5d8);
      color: #06090c;
    }
    .btn-add:hover {
      background: linear-gradient(135deg, #5ee0f5, #3cc2e5);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(78, 211, 232, 0.4);
    }
    .characters-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }
    .character-card {
      background: rgba(78, 211, 232, 0.05);
      border: 1px solid rgba(78, 211, 232, 0.2);
      border-radius: 12px;
      padding: 20px;
      transition: all 0.3s ease;
      position: relative;
    }
    .character-card:hover {
      background: rgba(78, 211, 232, 0.1);
      border-color: rgba(78, 211, 232, 0.4);
      transform: translateY(-3px);
      box-shadow: 0 6px 20px rgba(78, 211, 232, 0.15);
    }
    .character-name {
      font-size: 20px;
      color: #4ed3e8;
      margin-bottom: 8px;
      letter-spacing: 2px;
    }
    .character-class {
      font-size: 13px;
      color: #ff7a3d;
      margin-bottom: 12px;
      letter-spacing: 1px;
    }
    .character-stats {
      font-size: 12px;
      color: #99aabb;
      line-height: 1.8;
    }
    .btn-remove {
      position: absolute;
      top: 15px;
      right: 15px;
      background: transparent;
      border: 1px solid rgba(255, 100, 100, 0.5);
      color: #ff6464;
      width: 28px;
      height: 28px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
    }
    .btn-remove:hover {
      background: rgba(255, 100, 100, 0.2);
      border-color: #ff6464;
    }
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #666;
      font-size: 14px;
    }
    /* Modal Styles */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(6, 9, 12, 0.9);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
    }
    .modal-overlay.active {
      opacity: 1;
      visibility: visible;
    }
    .modal {
      background: #0a0f14;
      border: 1px solid rgba(78, 211, 232, 0.3);
      border-radius: 12px;
      padding: 30px;
      width: 100%;
      max-width: 450px;
      transform: scale(0.9);
      transition: all 0.3s ease;
    }
    .modal-overlay.active .modal {
      transform: scale(1);
    }
    .modal h2 {
      color: #4ed3e8;
      font-size: 22px;
      letter-spacing: 3px;
      margin-bottom: 25px;
      text-align: center;
    }
    .form-group {
      margin-bottom: 20px;
    }
    .form-group label {
      display: block;
      color: #99aabb;
      font-size: 12px;
      letter-spacing: 1px;
      margin-bottom: 8px;
      text-transform: uppercase;
    }
    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 12px;
      background: rgba(78, 211, 232, 0.05);
      border: 1px solid rgba(78, 211, 232, 0.2);
      border-radius: 8px;
      color: #cfe9f0;
      font-size: 14px;
      font-family: inherit;
    }
    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: #4ed3e8;
      box-shadow: 0 0 0 3px rgba(78, 211, 232, 0.1);
    }
    .modal-actions {
      display: flex;
      gap: 12px;
      justify-content: flex-end;
      margin-top: 25px;
    }
    .btn-cancel {
      background: transparent;
      border: 1px solid rgba(153, 170, 187, 0.3);
      color: #99aabb;
    }
    .btn-cancel:hover {
      border-color: #99aabb;
      background: rgba(153, 170, 187, 0.1);
    }
    .btn-save {
      background: linear-gradient(135deg, #4ed3e8, #2cb5d8);
      color: #06090c;
    }
    .btn-save:hover {
      background: linear-gradient(135deg, #5ee0f5, #3cc2e5);
    }
    .back-link {
      position: fixed;
      top: 20px;
      left: 20px;
      color: #666;
      text-decoration: none;
      font-size: 13px;
      transition: color 0.2s;
    }
    .back-link:hover {
      color: #4ed3e8;
    }
  </style>
</head>
<body>
  <a href="index.html" class="back-link">← Voltar</a>
  
  <div class="container">
    <h1>Personagens</h1>
    <p class="subtitle">GERENCIAMENTO DE PERSONAGENS</p>
    
    <div class="btn-container">
      <button class="btn btn-add" onclick="openModal()">+ Adicionar Personagem</button>
    </div>
    
    <div id="charactersList" class="characters-list">
      <!-- Personagens serão renderizados aqui via JS -->
    </div>
    
    <div id="emptyState" class="empty-state">
      <p>Nenhum personagem cadastrado.</p>
      <p style="margin-top: 10px; opacity: 0.6;">Clique em "Adicionar Personagem" para começar.</p>
    </div>
  </div>
  
  <!-- Modal de Adicionar Personagem -->
  <div id="modalOverlay" class="modal-overlay">
    <div class="modal">
      <h2>Novo Personagem</h2>
      <form id="characterForm" onsubmit="saveCharacter(event)">
        <div class="form-group">
          <label for="charName">Nome</label>
          <input type="text" id="charName" required placeholder="Digite o nome do personagem">
        </div>
        <div class="form-group">
          <label for="charClass">Classe</label>
          <input type="text" id="charClass" required placeholder="Ex: Guerreiro, Mago, Ladino">
        </div>
        <div class="form-group">
          <label for="charLevel">Nível</label>
          <input type="number" id="charLevel" min="1" max="20" value="1" placeholder="1">
        </div>
        <div class="form-group">
          <label for="charDescription">Descrição</label>
          <textarea id="charDescription" rows="3" placeholder="Breve descrição do personagem"></textarea>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-cancel" onclick="closeModal()">Cancelar</button>
          <button type="submit" class="btn btn-save">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Recupera dados salvos ou inicia array vazio
    let characters = JSON.parse(localStorage.getItem('rpg_characters') || '[]');
    
    function renderCharacters() {
      const list = document.getElementById('charactersList');
      const emptyState = document.getElementById('emptyState');
      
      if (characters.length === 0) {
        list.innerHTML = '';
        emptyState.style.display = 'block';
        return;
      }
      
      emptyState.style.display = 'none';
      list.innerHTML = characters.map((char, index) => `
        <div class="character-card">
          <button class="btn-remove" onclick="removeCharacter(${index})" title="Excluir">×</button>
          <div class="character-name">${escapeHtml(char.name)}</div>
          <div class="character-class">${escapeHtml(char.class)} • Nível ${char.level}</div>
          <div class="character-stats">${escapeHtml(char.description || 'Sem descrição')}</div>
        </div>
      `).join('');
    }
    
    function openModal() {
      document.getElementById('modalOverlay').classList.add('active');
      document.getElementById('charName').focus();
    }
    
    function closeModal() {
      document.getElementById('modalOverlay').classList.remove('active');
      document.getElementById('characterForm').reset();
    }
    
    function saveCharacter(event) {
      event.preventDefault();
      
      const newChar = {
        name: document.getElementById('charName').value.trim(),
        class: document.getElementById('charClass').value.trim(),
        level: parseInt(document.getElementById('charLevel').value) || 1,
        description: document.getElementById('charDescription').value.trim()
      };
      
      characters.push(newChar);
      localStorage.setItem('rpg_characters', JSON.stringify(characters));
      
      closeModal();
      renderCharacters();
    }
    
    function removeCharacter(index) {
      if (confirm(`Tem certeza que deseja excluir "${characters[index].name}"?`)) {
        characters.splice(index, 1);
        localStorage.setItem('rpg_characters', JSON.stringify(characters));
        renderCharacters();
      }
    }
    
    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
    
    document.getElementById('modalOverlay').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });
    
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });
    
    // Inicia a lista ao carregar a página
    renderCharacters();
  </script>
</body>
</html>
